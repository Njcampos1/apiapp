# ─────────────────────────────────────────────────────────────────
# Upper Coffee — Variables de entorno
# Copia este archivo a .env y completa con tus credenciales REALES.
# NUNCA subas el .env al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────

# ── WooCommerce ───────────────────────────────────────────────────
# URL base de tu tienda (sin barra al final)
WOO_URL=https://tu-tienda.ejemplo.cl

# Consumer Key y Secret generados en:
# WooCommerce → Ajustes → Avanzado → REST API → Agregar clave
# Permisos necesarios: Lectura/Escritura
WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Impresora Zebra ───────────────────────────────────────────────
# IP estática de la impresora en la red local de bodega
ZEBRA_IP=192.168.1.100
ZEBRA_PORT=9100
# Resolución: 203 (estándar) o 300 (alta definición)
ZEBRA_DPI=300

# ── Aplicación Web ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# En true: logs detallados y recarga automática (solo desarrollo local)
DEBUG=false

# Ruta de la base de datos SQLite
DB_PATH=pedidos.db

# ── Autenticación local (JWT) ────────────────────────────────────
# Clave secreta para firmar tokens JWT (usar una cadena larga y aleatoria)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REEMPLAZAR-CON-CLAVE-ALEATORIA-DE-64-CHARS
# Duración del token en minutos
JWT_EXPIRE_MINUTES=720
# Usuario administrador inicial (se crea automáticamente si no existe)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=REEMPLAZAR-ANTES-DE-DESPLEGAR

# ── Azure Container Registry (solo para despliegue en la nube) ────
# Dejar vacío en desarrollo local
AZURE_REGISTRY=
AZURE_IMAGE_NAME=upperapp-logistics

# ── Mercado Libre ─────────────────────────────────────────────────
# Crea tu aplicación en: https://developers.mercadolibre.cl/es_ar/registra-tu-aplicacion
#
# App ID (también llamado Client ID) de tu aplicación MeLi
MELI_APP_ID=
#
# Secret Key de tu aplicación MeLi
MELI_CLIENT_SECRET=
#
# URI de redirección registrada en el panel de MeLi.
# Debe coincidir EXACTAMENTE con la que configuraste allí.
# Ejemplo en Azure: https://tu-app.azurewebsites.net/api/meli/callback
# Ejemplo local:    http://localhost:8000/api/meli/callback
MELI_REDIRECT_URI=http://localhost:8000/api/meli/callback
#
# ── Cómo autorizar (una sola vez por despliegue) ──────────────────
# 1. Con la app corriendo, navega en el navegador a:
#      https://auth.mercadolibre.cl/authorization
#        ?response_type=code
#        &client_id=<MELI_APP_ID>
#        &redirect_uri=<MELI_REDIRECT_URI>
#        &scope=read_billing_info%20offline_access
# 2. Inicia sesión con la cuenta del vendedor y acepta los permisos.
#    IMPORTANTE: si ya autorizaste sin este scope, debes revocar y re-autorizar.
# 3. MeLi redirigirá a MELI_REDIRECT_URI?code=TU_CODE
#    El sistema captura el code, obtiene los tokens y los persiste en SQLite.
# 4. Los tokens se refrescan automáticamente cada 6 horas.
