# ─────────────────────────────────────────────────────────────────
# Upper Coffee — Variables de entorno
# Copia este archivo a .env y completa con tus credenciales REALES.
# NUNCA subas el .env al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────

# ── WooCommerce ───────────────────────────────────────────────────
# URL base de tu tienda (sin barra al final)
WOO_URL=https://tu-tienda.ejemplo.cl

# Consumer Key y Secret generados en:
# WooCommerce → Ajustes → Avanzado → REST API → Agregar clave
# Permisos necesarios: Lectura/Escritura
WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Impresora Zebra ───────────────────────────────────────────────
# IP estática de la impresora en la red local de bodega
ZEBRA_IP=192.168.1.100
ZEBRA_PORT=9100
# Resolución: 203 (estándar) o 300 (alta definición)
ZEBRA_DPI=300

# ── Aplicación Web ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# En true: logs detallados y recarga automática (solo desarrollo local)
DEBUG=false

# Ruta de la base de datos SQLite
DB_PATH=pedidos.db

# ── Azure Container Registry (solo para despliegue en la nube) ────
# Dejar vacío en desarrollo local
AZURE_REGISTRY=
AZURE_IMAGE_NAME=upperapp-logistics
